.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sl-space-3);
}

.summary-item {
  border: 1rpx solid var(--sl-color-border);
  border-radius: var(--sl-radius-md);
  background: var(--sl-color-surface-soft);
  padding: var(--sl-space-3);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.summary-item__label {
  font-size: var(--sl-font-size-xs);
  color: var(--sl-color-text-muted);
}

.summary-item__value {
  font-size: var(--sl-font-size-xl);
  font-weight: 700;
  color: var(--sl-color-text-primary);
}

.entry-card {
  padding: var(--sl-space-3) 0;
  display: flex;
  gap: var(--sl-space-3);
  border-bottom: 1rpx dashed var(--sl-color-border);
}

.entry-card:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.entry-card--disabled {
  opacity: 0.74;
}

.entry-card__main {
  flex: 1;
  min-width: 0;
}

.entry-card__name {
  font-size: var(--sl-font-size-md);
  font-weight: 700;
  color: var(--sl-color-text-primary);
  line-height: var(--sl-line-height-tight);
}

.entry-card__desc {
  margin-top: 8rpx;
  font-size: var(--sl-font-size-xs);
  color: var(--sl-color-text-secondary);
  line-height: var(--sl-line-height-relaxed);
}

.entry-card__hint {
  margin-top: 8rpx;
  font-size: var(--sl-font-size-xs);
  color: var(--sl-color-text-muted);
}

.entry-card__side {
  min-width: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.entry-card__todo-label {
  font-size: var(--sl-font-size-xs);
  color: var(--sl-color-text-muted);
}

.entry-card__action {
  min-width: 132rpx;
}
