.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 62rpx;
  border-bottom: 1rpx dashed rgba(216, 224, 234, 0.9);
  padding: 8rpx 0;
}

.row:last-child {
  border-bottom: 0;
}

.label {
  color: var(--sl-color-text-secondary);
  font-size: var(--sl-font-size-sm);
}

.value {
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  font-weight: 600;
  text-align: right;
}

.value--source {
  max-width: 62%;
}

.action-row {
  margin-top: 14rpx;
}

.map {
  width: 100%;
  height: 420rpx;
  border-radius: var(--sl-radius-lg);
  overflow: hidden;
  border: 1rpx solid var(--sl-color-border);
}

.map-error,
.map-empty {
  min-height: 260rpx;
  display: flex;
  align-items: center;
}

.empty {
  color: var(--sl-color-text-muted);
  font-size: var(--sl-font-size-sm);
}

.port-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 62rpx;
  padding: 8rpx 0;
  border-bottom: 1rpx dashed rgba(216, 224, 234, 0.9);
}

.port-row:last-child {
  border-bottom: 0;
}

.port-name {
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  font-weight: 600;
}

.port-extra {
  color: var(--sl-color-text-muted);
  font-size: var(--sl-font-size-xs);
}
