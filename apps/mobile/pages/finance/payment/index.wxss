.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 58rpx;
  padding: 8rpx 0;
}

.label {
  color: var(--sl-color-text-secondary);
  font-size: var(--sl-font-size-sm);
}

.value {
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
}

.strong {
  color: var(--sl-color-danger);
  font-weight: 700;
}

.warn-banner {
  margin-bottom: 14rpx;
  border: 1rpx solid #efb4b1;
  background: var(--sl-color-danger-bg);
  color: #9d1c15;
  border-radius: var(--sl-radius-md);
  padding: 12rpx;
  font-size: var(--sl-font-size-xs);
  line-height: var(--sl-line-height-relaxed);
}

.disabled-note {
  margin-bottom: 12rpx;
  border: 1rpx solid #f0c68f;
  border-radius: var(--sl-radius-md);
  background: var(--sl-color-warning-bg);
  padding: 10rpx 12rpx;
  font-size: var(--sl-font-size-xs);
  color: var(--sl-color-warning);
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.form-row--column {
  display: block;
}

.form-label {
  color: var(--sl-color-text-secondary);
  font-size: var(--sl-font-size-sm);
}

.form-input {
  width: 300rpx;
  min-height: var(--sl-hit-area-md);
  border: 1rpx solid var(--sl-color-border);
  border-radius: var(--sl-radius-md);
  padding: 0 12rpx;
  text-align: right;
  box-sizing: border-box;
}

.picker-value {
  min-width: 220rpx;
  min-height: var(--sl-hit-area-md);
  border: 1rpx solid var(--sl-color-border);
  border-radius: var(--sl-radius-md);
  padding: 0 12rpx;
  text-align: right;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  box-sizing: border-box;
}

.remark-input {
  margin-top: 8rpx;
  width: 100%;
  min-height: 130rpx;
  border: 1rpx solid var(--sl-color-border);
  border-radius: var(--sl-radius-md);
  padding: 12rpx;
  box-sizing: border-box;
}

.pay-item {
  border-bottom: 1rpx dashed rgba(216, 224, 234, 0.9);
  padding: 10rpx 0 14rpx;
}

.pay-item:last-child {
  border-bottom: none;
}

.pay-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.reverse-btn {
  margin-top: 8rpx;
  min-width: 180rpx;
}
