<sl-page-shell
  title="磅单"
  subtitle="财务结算流程中的磅单列表"
  loading="{{loading}}"
  showError="{{showError}}"
  showEmpty="{{!loading && !showError && !list.length}}"
  emptyText="暂无磅单"
  bind:retry="onRetry"
>
  <sl-top-filter-bar
    slot="filter"
    filters="{{filters}}"
    activeKey="{{activeStatus}}"
    showSearch="{{true}}"
    searchPlaceholder="磅单号 / 销售单号 / 客户"
    bind:change="onFilterChange"
    bind:search="onSearch"
  />

  <sl-business-card
    wx:for="{{list}}"
    wx:key="id"
    title="{{item.slipNo}}"
    subtitle="{{item.salesOrderNo}} / {{item.customerName}}"
    extra="{{item.statusText}}"
    extraTone="{{item.statusTone}}"
    clickable
    data-id="{{item.id}}"
    bind:cardtap="onTapDetail"
  >
    <view class="row"><text class="label">销售订单</text><text class="value">{{item.salesOrderNo}}</text></view>
    <view class="row"><text class="label">订单状态</text><text class="value">{{item.orderStatusText}}</text></view>
    <view class="row"><text class="label">应收状态</text><text class="value">{{item.arStatusText}}</text></view>
    <view class="row"><text class="label">计划吨数</text><text class="value">{{item.plannedQty}}</text></view>
    <view class="row"><text class="label">最终吨数</text><text class="value">{{item.finalTotalQty}}</text></view>
    <view class="row">
      <text class="label">差异</text>
      <sl-status-tag text="{{item.deltaQty}}" type="{{item.diffTone}}" />
    </view>
    <view class="actions">
      <sl-button class="btn" text="详情" type="secondary" size="small" data-id="{{item.id}}" bind:tap="onTapDetail" />
    </view>
  </sl-business-card>

  <sl-bottom-action-bar
    slot="footer"
    primaryText="财务待办"
    bind:primarytap="onTapPending"
  />
</sl-page-shell>
