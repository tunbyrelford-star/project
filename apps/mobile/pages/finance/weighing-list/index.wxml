<sl-page-shell
  title="Weighing Slip Orders"
  subtitle="Weighing slip list for finance closure workflow"
  loading="{{loading}}"
  showError="{{showError}}"
  showEmpty="{{!loading && !showError && !list.length}}"
  emptyText="No weighing slips"
  bind:retry="onRetry"
>
  <sl-top-filter-bar
    slot="filter"
    filters="{{filters}}"
    activeKey="{{activeStatus}}"
    showSearch="{{true}}"
    searchPlaceholder="Slip no / Sales order / Customer"
    bind:change="onFilterChange"
    bind:search="onSearch"
  />

  <sl-business-card
    wx:for="{{list}}"
    wx:key="id"
    title="{{item.slipNo}}"
    subtitle="{{item.salesOrderNo}} / {{item.customerName}}"
    extra="{{item.status}}"
    extraTone="{{item.statusTone}}"
    clickable
    data-id="{{item.id}}"
    bind:cardtap="onTapDetail"
  >
    <view class="row"><text class="label">Sales Order</text><text class="value">{{item.salesOrderNo}}</text></view>
    <view class="row"><text class="label">Order Status</text><text class="value">{{item.orderStatus}}</text></view>
    <view class="row"><text class="label">AR Status</text><text class="value">{{item.arStatus}}</text></view>
    <view class="row"><text class="label">Planned Qty</text><text class="value">{{item.plannedQty}}</text></view>
    <view class="row"><text class="label">Final Qty</text><text class="value">{{item.finalTotalQty}}</text></view>
    <view class="row">
      <text class="label">Delta</text>
      <sl-status-tag text="{{item.deltaQty}}" type="{{item.diffTone}}" />
    </view>
    <view class="actions">
      <sl-button class="btn" text="Detail" type="secondary" size="small" data-id="{{item.id}}" bind:tap="onTapDetail" />
    </view>
  </sl-business-card>

  <sl-bottom-action-bar
    slot="footer"
    primaryText="Pending Finance Actions"
    bind:primarytap="onTapPending"
  />
</sl-page-shell>
