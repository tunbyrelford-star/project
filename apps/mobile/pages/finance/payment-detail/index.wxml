<sl-page-shell
  title="Payment Detail"
  subtitle="{{detail.paymentNo || ''}}"
  loading="{{loading}}"
  showError="{{showError}}"
  bind:retry="onRetry"
>
  <sl-business-card title="Payment Info">
    <view class="row"><text class="label">Payment No</text><text class="value">{{detail.paymentNo || '-'}}</text></view>
    <view class="row"><text class="label">Status</text><text class="value">{{detail.status || '-'}}</text></view>
    <view class="row"><text class="label">Sales Order</text><text class="value">{{detail.salesOrderNo || '-'}}</text></view>
    <view class="row"><text class="label">Customer</text><text class="value">{{detail.customerName || '-'}}</text></view>
    <view class="row"><text class="label">AR Status</text><text class="value">{{detail.arStatus || '-'}}</text></view>
    <view class="row"><text class="label">Amount</text><text class="value">{{detail.paymentAmount || '-'}}</text></view>
    <view class="row"><text class="label">Method</text><text class="value">{{detail.paymentMethod || '-'}}</text></view>
    <view class="row"><text class="label">Type</text><text class="value">{{detail.isReversal ? 'REVERSAL' : 'NORMAL'}}</text></view>
    <view class="row"><text class="label">Paid At</text><text class="value">{{detail.paidAt || '-'}}</text></view>
    <view class="row"><text class="label">Remark</text><text class="value">{{detail.remark || '-'}}</text></view>
  </sl-business-card>

  <sl-business-card title="Receipt Summary">
    <view class="row"><text class="label">Incoming Amount</text><text class="value">{{receipt.incomingAmount || 0}}</text></view>
    <view class="row"><text class="label">Reversed Amount</text><text class="value">{{receipt.reversedAmount || 0}}</text></view>
    <view class="row"><text class="label">Net Confirmed</text><text class="value">{{receipt.netConfirmedAmount || 0}}</text></view>
    <view class="row"><text class="label">Outstanding</text><text class="value">{{receipt.outstandingAmount || 0}}</text></view>
    <view class="row"><text class="label">Receipt Status</text><text class="value">{{receipt.receiptStatus || '-'}}</text></view>
  </sl-business-card>

  <sl-business-card title="Reverse by Offset">
    <view class="warn">
      Confirmed payment cannot be revoked. You can only reverse by creating an offset record.
    </view>
    <view class="form-row">
      <text class="form-label">Reversal Reason</text>
      <textarea
        class="reason-input"
        maxlength="255"
        value="{{reversalReason}}"
        bindinput="onReasonInput"
        placeholder="Input reversal reason"
      />
    </view>
    <sl-button
      text="Reverse This Payment"
      type="danger"
      size="small"
      loading="{{reversing}}"
      disabled="{{!detail.canReverse || reversing}}"
      bind:tap="onReverse"
    />
  </sl-business-card>

  <sl-business-card title="Audit">
    <sl-audit-timeline items="{{audits}}" />
  </sl-business-card>

  <sl-bottom-action-bar
    slot="footer"
    secondaryText="Payment List"
    secondaryType="secondary"
    bind:secondarytap="onToList"
    primaryText="Open Payment Confirm Page"
    bind:primarytap="onGoConfirmPage"
  />
</sl-page-shell>
