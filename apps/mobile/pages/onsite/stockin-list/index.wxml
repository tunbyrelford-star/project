<sl-page-shell
  title="入库单"
  subtitle="库存入库确认单据"
  loading="{{loading}}"
  showError="{{showError}}"
  showEmpty="{{!loading && !showError && !list.length}}"
  emptyText="暂无入库单"
  bind:retry="onRetry"
>
  <sl-top-filter-bar
    slot="filter"
    filters="{{filters}}"
    activeKey="{{activeStatus}}"
    showSearch="{{true}}"
    searchPlaceholder="入库单号 / 批次号 / 航次号 / 船名"
    bind:change="onFilterChange"
    bind:search="onSearch"
  />

  <sl-business-card
    wx:for="{{list}}"
    wx:key="id"
    title="{{item.stockInNo}}"
    subtitle="{{item.batchNo}} / {{item.voyageNo}}"
    extra="{{item.statusText}}"
    extraTone="{{item.statusTone}}"
    clickable
    data-id="{{item.id}}"
    bind:cardtap="onTapDetail"
  >
    <view class="row"><text class="label">批次</text><text class="value">{{item.batchNo}}</text></view>
    <view class="row"><text class="label">航次</text><text class="value">{{item.voyageNo}}</text></view>
    <view class="row"><text class="label">船名</text><text class="value">{{item.shipName}}</text></view>
    <view class="row"><text class="label">确认吨数</text><text class="value">{{item.confirmedQty}}</text></view>
    <view class="row"><text class="label">版本</text><text class="value">v{{item.versionNo}}</text></view>
    <view class="row"><text class="label">入库时间</text><text class="value">{{item.stockInTime || '-'}}</text></view>
    <view class="actions">
      <sl-button class="btn" text="详情" type="secondary" size="small" data-id="{{item.id}}" bind:tap="onTapDetail" />
      <sl-button class="btn" text="确认页" type="tertiary" size="small" data-batch-id="{{item.batchId}}" bind:tap="onTapConfirm" />
    </view>
  </sl-business-card>

  <sl-bottom-action-bar
    slot="footer"
    primaryText="入库待办"
    bind:primarytap="onTapTodo"
  />
</sl-page-shell>
