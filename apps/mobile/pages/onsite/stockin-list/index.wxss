.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 56rpx;
  border-bottom: 1rpx dashed var(--sl-color-border);
}

.row:last-child {
  border-bottom: 0;
}

.label {
  color: var(--sl-color-text-secondary);
  font-size: var(--sl-font-size-xs);
}

.value {
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  text-align: right;
}

.actions {
  display: flex;
  gap: var(--sl-space-2);
  justify-content: flex-end;
  padding-top: var(--sl-space-2);
}

.btn {
  min-width: 132rpx;
}
