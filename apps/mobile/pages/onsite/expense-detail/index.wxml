<sl-page-shell
  title="费用单详情"
  subtitle="{{detail.expenseNo || ''}}"
  loading="{{loading}}"
  showError="{{showError}}"
  bindretry="onRetry"
>
  <sl-business-card title="费用信息">
    <view class="row"><text class="label">费用单号</text><text class="value">{{detail.expenseNo || '-'}}</text></view>
    <view class="row"><text class="label">状态</text><text class="value">{{detail.statusText || '-'}}</text></view>
    <view class="row"><text class="label">航次</text><text class="value">{{detail.voyageNo || '-'}}</text></view>
    <view class="row"><text class="label">船名</text><text class="value">{{detail.shipName || '-'}}</text></view>
    <view class="row"><text class="label">费用类型</text><text class="value">{{detail.expenseTypeText || '-'}}</text></view>
    <view class="row"><text class="label">金额</text><text class="value">{{detail.amountDisplay || '-'}}</text></view>
    <view class="row"><text class="label">发生时间</text><text class="value">{{detail.occurredAtText || '-'}}</text></view>
    <view class="row"><text class="label">来源模块</text><text class="value">{{detail.sourceModuleText || '-'}}</text></view>
  </sl-business-card>

  <sl-business-card title="凭证">
    <sl-attachment-uploader
      title="凭证文件"
      readonly="{{true}}"
      maxCount="{{99}}"
      value="{{files}}"
    />
  </sl-business-card>

  <sl-business-card title="审计记录">
    <sl-audit-timeline items="{{audits}}" />
  </sl-business-card>

  <sl-bottom-action-bar
    slot="footer"
    secondaryText="费用单列表"
    secondaryType="secondary"
    bindsecondarytap="onToList"
    primaryText="新建费用单"
    bindprimarytap="onCreateWithVoyage"
  />
</sl-page-shell>
