<sl-page-shell
  title="过驳单"
  subtitle="过驳作业与卸空确认流程"
  loading="{{loading}}"
  showError="{{showError}}"
  showEmpty="{{!loading && !showError && !list.length}}"
  emptyText="暂无过驳单"
  bind:retry="onRetry"
>
  <sl-top-filter-bar
    slot="filter"
    filters="{{filters}}"
    activeKey="{{activeStatus}}"
    showSearch="{{true}}"
    searchPlaceholder="过驳单号 / 航次号 / 船名"
    bind:change="onFilterChange"
    bind:search="onSearch"
  />

  <sl-business-card
    wx:for="{{list}}"
    wx:key="id"
    title="{{item.lighteringNo}}"
    subtitle="{{item.voyageNo}} / {{item.shipName}}"
    extra="{{item.statusText}}"
    extraTone="{{item.statusTone}}"
    clickable
    data-id="{{item.id}}"
    bind:cardtap="onTapDetail"
  >
    <view class="row"><text class="label">航次</text><text class="value">{{item.voyageNo}}</text></view>
    <view class="row"><text class="label">船名</text><text class="value">{{item.shipName}}</text></view>
    <view class="row"><text class="label">主船卸空</text><text class="value">{{item.unloadText}}</text></view>
    <view class="row"><text class="label">开始时间</text><text class="value">{{item.startedAt || '-'}}</text></view>
    <view class="row"><text class="label">确认时间</text><text class="value">{{item.confirmedAt || '-'}}</text></view>
    <view class="actions">
      <sl-button class="btn" text="详情" type="secondary" size="small" data-id="{{item.id}}" bind:tap="onTapDetail" />
      <sl-button
        class="btn"
        text="确认卸空"
        type="primary"
        size="small"
        data-id="{{item.id}}"
        loading="{{actionId === item.id}}"
        disabled="{{!item.canConfirmEmpty || (actionId > 0 && actionId !== item.id)}}"
        bind:tap="onTapConfirm"
      />
    </view>
  </sl-business-card>

  <sl-bottom-action-bar
    slot="footer"
    primaryText="现场待办"
    bind:primarytap="onTapTaskBoard"
  />
</sl-page-shell>
