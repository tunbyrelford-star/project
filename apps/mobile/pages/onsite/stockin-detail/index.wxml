<sl-page-shell
  title="Stock-In Detail"
  subtitle="{{detail.stockInNo || ''}}"
  loading="{{loading}}"
  showError="{{showError}}"
  bind:retry="onRetry"
>
  <sl-business-card title="Stock-In Info">
    <view class="row"><text class="label">Stock-In No</text><text class="value">{{detail.stockInNo || '-'}}</text></view>
    <view class="row"><text class="label">Status</text><text class="value">{{detail.status || '-'}}</text></view>
    <view class="row"><text class="label">Batch</text><text class="value">{{detail.batchNo || '-'}}</text></view>
    <view class="row"><text class="label">Voyage</text><text class="value">{{detail.voyageNo || '-'}}</text></view>
    <view class="row"><text class="label">Ship</text><text class="value">{{detail.shipName || '-'}}</text></view>
    <view class="row"><text class="label">Confirmed Qty</text><text class="value">{{detail.confirmedQty || '-'}}</text></view>
    <view class="row"><text class="label">Available Qty</text><text class="value">{{detail.availableQty || '-'}}</text></view>
    <view class="row"><text class="label">Stock-In Confirmed</text><text class="value">{{detail.stockInConfirmed ? 'Yes' : 'No'}}</text></view>
    <view class="row"><text class="label">Version</text><text class="value">v{{detail.versionNo || '-'}}</text></view>
    <view class="row"><text class="label">Stock-In Time</text><text class="value">{{detail.stockInTime || '-'}}</text></view>
    <view class="row"><text class="label">Remark</text><text class="value">{{detail.remark || '-'}}</text></view>
  </sl-business-card>

  <sl-business-card title="Evidence">
    <sl-attachment-uploader
      title="Evidence Files"
      readonly="{{true}}"
      maxCount="{{99}}"
      value="{{files}}"
    />
  </sl-business-card>

  <sl-business-card title="Audit">
    <sl-audit-timeline items="{{audits}}" />
  </sl-business-card>

  <sl-bottom-action-bar
    slot="footer"
    secondaryText="Order List"
    secondaryType="secondary"
    bind:secondarytap="onToList"
    primaryText="Open Confirm Page"
    bind:primarytap="onGoConfirm"
  />
</sl-page-shell>
