<sl-page-shell
  title="费用单"
  subtitle="航次费用单据与金额查看管理"
  loading="{{loading}}"
  showError="{{showError}}"
  showEmpty="{{!loading && !showError && !list.length}}"
  emptyText="暂无费用单"
  bind:retry="onRetry"
>
  <sl-top-filter-bar
    slot="filter"
    filters="{{filters}}"
    activeKey="{{activeStatus}}"
    showSearch="{{true}}"
    searchPlaceholder="费用单号 / 航次号 / 船名"
    bind:change="onFilterChange"
    bind:search="onSearch"
  />

  <view class="condition-row">
    <picker mode="selector" range="{{typeOptions}}" range-key="label" value="{{typeIndex}}" bindchange="onTypeChange">
      <view class="condition-pill">{{typeOptions[typeIndex].label}}</view>
    </picker>
  </view>

  <sl-business-card
    wx:for="{{list}}"
    wx:key="id"
    title="{{item.expenseNo}}"
    subtitle="{{item.voyageNo}} / {{item.shipName}}"
    extra="{{item.statusText}}"
    extraTone="{{item.statusTone}}"
    clickable
    data-id="{{item.id}}"
    bind:cardtap="onTapDetail"
  >
    <view class="row"><text class="label">航次</text><text class="value">{{item.voyageNo}}</text></view>
    <view class="row"><text class="label">费用类型</text><text class="value">{{item.expenseTypeText}}</text></view>
    <view class="row"><text class="label">金额</text><text class="value">{{item.amountDisplay}}</text></view>
    <view class="row"><text class="label">发生时间</text><text class="value">{{item.occurredAt || '-'}}</text></view>
    <view class="actions">
      <sl-button class="btn" text="详情" type="secondary" size="small" data-id="{{item.id}}" bind:tap="onTapDetail" />
    </view>
  </sl-business-card>

  <sl-bottom-action-bar
    slot="footer"
    primaryText="新增费用单"
    bind:primarytap="onTapCreate"
  />
</sl-page-shell>
