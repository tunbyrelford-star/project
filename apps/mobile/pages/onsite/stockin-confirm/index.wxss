.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 62rpx;
  border-bottom: 1rpx dashed rgba(216, 224, 234, 0.9);
  padding: 8rpx 0;
}

.row:last-child {
  border-bottom: 0;
}

.label {
  color: var(--sl-color-text-secondary);
  font-size: var(--sl-font-size-sm);
}

.value {
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  font-weight: 700;
}

.form-row {
  margin-bottom: 16rpx;
}

.form-row:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  color: var(--sl-color-text-secondary);
  font-size: var(--sl-font-size-xs);
  margin-bottom: 8rpx;
}

.form-input {
  min-height: var(--sl-hit-area-md);
  border: 1rpx solid var(--sl-color-border);
  border-radius: var(--sl-radius-md);
  background: #ffffff;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  box-sizing: border-box;
}
