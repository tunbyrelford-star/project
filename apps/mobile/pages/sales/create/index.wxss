.form-row {
  margin-bottom: 16rpx;
}

.form-row:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  color: var(--sl-color-text-secondary);
  font-size: var(--sl-font-size-xs);
  margin-bottom: 8rpx;
}

.form-input {
  min-height: var(--sl-hit-area-md);
  border: 1rpx solid var(--sl-color-border);
  border-radius: var(--sl-radius-md);
  background: #ffffff;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  box-sizing: border-box;
}

.batch-toolbar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
  min-width: 0;
}

.tool-btn {
  margin: 0;
  flex: 1;
  min-width: 0;
}

.empty {
  color: var(--sl-color-text-muted);
  font-size: var(--sl-font-size-sm);
}

.batch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid var(--sl-color-border);
  border-radius: var(--sl-radius-md);
  padding: 12rpx;
  margin-bottom: 10rpx;
  background: #ffffff;
}

.batch-main {
  display: flex;
  flex-direction: column;
}

.batch-title {
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  font-weight: 700;
}

.batch-sub {
  color: var(--sl-color-text-muted);
  font-size: var(--sl-font-size-xs);
  margin-top: 4rpx;
}

.batch-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.qty-input {
  width: 170rpx;
  min-height: 60rpx;
  border: 1rpx solid var(--sl-color-border);
  border-radius: var(--sl-radius-sm);
  padding: 0 10rpx;
  box-sizing: border-box;
  font-size: var(--sl-font-size-xs);
}

.remove-btn {
  margin: 0;
  min-width: 126rpx;
}

.preview-item {
  border: 1rpx solid var(--sl-color-border);
  border-radius: var(--sl-radius-md);
  padding: 12rpx;
  margin-bottom: 10rpx;
  background: #ffffff;
}

.preview-head {
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  font-weight: 700;
  margin-bottom: 8rpx;
}

.preview-row,
.totals-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 56rpx;
  border-bottom: 1rpx dashed rgba(216, 224, 234, 0.9);
}

.preview-row:last-child,
.totals-row:last-child {
  border-bottom: 0;
}

.label {
  color: var(--sl-color-text-secondary);
  font-size: var(--sl-font-size-xs);
}

.value {
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  font-weight: 600;
}

.totals {
  margin-top: 8rpx;
  border-top: 1rpx solid var(--sl-color-border);
  padding-top: 8rpx;
}
