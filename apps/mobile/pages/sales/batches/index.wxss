.condition-row {
  display: flex;
  gap: 12rpx;
  padding: 0 0 14rpx;
}

.condition-pill {
  min-width: 220rpx;
  min-height: 64rpx;
  border: 1rpx solid var(--sl-color-border);
  border-radius: var(--sl-radius-md);
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  background: #ffffff;
  box-sizing: border-box;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 62rpx;
  border-bottom: 1rpx dashed rgba(216, 224, 234, 0.9);
  padding: 8rpx 0;
}

.row:last-child {
  border-bottom: 0;
}

.row__label {
  color: var(--sl-color-text-secondary);
  font-size: var(--sl-font-size-sm);
}

.row__value {
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  font-weight: 600;
}

.disabled-reason {
  margin-top: 8rpx;
  border: 1rpx solid #efb4b1;
  border-radius: var(--sl-radius-md);
  background: var(--sl-color-danger-bg);
  color: var(--sl-color-danger);
  font-size: var(--sl-font-size-xs);
  line-height: var(--sl-line-height-relaxed);
  padding: 10rpx 12rpx;
}

.row--action {
  padding-top: 14rpx;
  border-bottom: 0;
}

.next-btn {
  margin: 0;
  min-width: 180rpx;
}
