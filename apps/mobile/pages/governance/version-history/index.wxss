.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.label {
  color: var(--sl-color-text-secondary);
  font-size: var(--sl-font-size-sm);
}

.picker-value,
.input {
  min-width: 260rpx;
  min-height: var(--sl-hit-area-md);
  border: 1rpx solid var(--sl-color-border);
  border-radius: var(--sl-radius-md);
  padding: 0 12rpx;
  text-align: right;
  box-sizing: border-box;
}

.search-btn {
  margin-top: 6rpx;
  min-width: 190rpx;
}

.empty {
  color: var(--sl-color-text-muted);
  font-size: var(--sl-font-size-sm);
}

.version-row {
  border-bottom: 1rpx dashed rgba(216, 224, 234, 0.9);
  padding: 10rpx 0;
}

.version-row:last-child {
  border-bottom: none;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 54rpx;
}

.value {
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  max-width: 470rpx;
  text-align: right;
}
