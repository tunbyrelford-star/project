.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 58rpx;
  border-bottom: 1rpx dashed rgba(216, 224, 234, 0.9);
  padding: 8rpx 0;
}

.row:last-child {
  border-bottom: 0;
}

.label {
  color: var(--sl-color-text-secondary);
  font-size: var(--sl-font-size-sm);
}

.value {
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  font-weight: 600;
}
