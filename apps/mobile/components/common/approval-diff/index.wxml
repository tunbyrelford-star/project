<view class="diff">
  <view wx:if="{{!rows.length}}" class="diff__empty">暂无对比项</view>
  <view wx:for="{{rows}}" wx:key="field" class="diff__row {{item.changed ? 'diff__row--changed' : ''}}">
    <view class="diff__head">
      <view class="diff__field">{{item.label}}</view>
      <view class="diff__state {{item.changed ? 'diff__state--changed' : ''}}">{{item.changed ? '已变更' : '未变更'}}</view>
    </view>
    <view class="diff__col">
      <view class="diff__label">变更前</view>
      <view class="diff__value">{{item.before}}</view>
    </view>
    <view class="diff__col">
      <view class="diff__label">变更后</view>
      <view class="diff__value">{{item.after}}</view>
    </view>
  </view>
</view>
