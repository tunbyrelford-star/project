.diff__empty {
  text-align: center;
  color: var(--sl-color-text-muted);
  padding: 24rpx 0;
}

.diff__row {
  border: 1rpx solid var(--sl-color-border);
  border-radius: var(--sl-radius-md);
  padding: 14rpx;
  margin-bottom: var(--sl-space-2);
  background: #ffffff;
}

.diff__row--changed {
  border-color: #f0c68f;
  background: var(--sl-color-warning-bg);
}

.diff__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.diff__field {
  font-size: var(--sl-font-size-sm);
  font-weight: 700;
  color: var(--sl-color-text-primary);
}

.diff__state {
  border-radius: var(--sl-radius-pill);
  border: 1rpx solid var(--sl-color-border);
  background: var(--sl-color-surface-soft);
  color: var(--sl-color-text-muted);
  font-size: var(--sl-font-size-xs);
  padding: 4rpx 12rpx;
}

.diff__state--changed {
  border-color: #f0c68f;
  background: #fff3de;
  color: var(--sl-color-warning);
}

.diff__col {
  padding: 8rpx 0;
}

.diff__col + .diff__col {
  border-top: 1rpx dashed rgba(216, 224, 234, 0.8);
}

.diff__label {
  color: var(--sl-color-text-muted);
  font-size: var(--sl-font-size-xs);
}

.diff__value {
  margin-top: 4rpx;
  color: var(--sl-color-text-primary);
  font-size: var(--sl-font-size-sm);
  line-height: var(--sl-line-height-relaxed);
  word-break: break-all;
}
