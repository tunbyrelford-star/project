.attach__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--sl-space-3);
}

.attach__title {
  font-size: var(--sl-font-size-sm);
  color: var(--sl-color-text-secondary);
  font-weight: 600;
}

.attach__count {
  color: var(--sl-color-text-muted);
  font-size: var(--sl-font-size-xs);
}

.attach__empty {
  border: 1rpx dashed var(--sl-color-border);
  border-radius: var(--sl-radius-md);
  background: var(--sl-color-surface-soft);
  color: var(--sl-color-text-muted);
  text-align: center;
  padding: 20rpx;
  font-size: var(--sl-font-size-sm);
  margin-bottom: var(--sl-space-2);
}

.attach__item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  border: 1rpx solid var(--sl-color-border);
  border-radius: var(--sl-radius-md);
  padding: 12rpx 14rpx;
  margin-bottom: var(--sl-space-2);
  background: #ffffff;
}

.attach__meta {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}

.attach__icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  background: var(--sl-color-primary-weak);
  border: 1rpx solid #b9d2fb;
  margin-right: 12rpx;
}

.attach__text {
  min-width: 0;
  flex: 1;
}

.attach__name {
  font-size: var(--sl-font-size-sm);
  color: var(--sl-color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attach__size {
  margin-top: 2rpx;
  font-size: var(--sl-font-size-xs);
  color: var(--sl-color-text-muted);
}

.attach__status {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.attach__status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  background: #eef2f7;
  color: #607487;
}

.attach__status-pill.ok {
  background: #eaf8f1;
  color: #157347;
}

.attach__status-pill.fail {
  background: #feecee;
  color: #b3261e;
}

.attach__progress {
  font-size: var(--sl-font-size-xs);
  color: var(--sl-color-primary);
}

.attach__error {
  font-size: var(--sl-font-size-xs);
  color: var(--sl-color-danger);
}

.attach__ops {
  margin-left: var(--sl-space-2);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.attach__retry,
.attach__remove {
  min-width: 112rpx;
}

.attach__btn {
  width: 100%;
  margin-top: var(--sl-space-2);
}
